# Supabase — names only, real values live in .env.local (local) / Vercel (deploys).
# Local stack values are printed by `supabase start`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Google sign-in button — set to 1 only AFTER the Google provider is configured
# in Supabase (dashboard creds + redirect URLs). Off by default.
NEXT_PUBLIC_AUTH_GOOGLE=

# Email magic-link button — set to 1 only when a working mail sender exists
# (local: Mailpit via `supabase start`; prod: custom SMTP / Resend + a verified
# domain). Off by default so testers don't hit the rate-limited built-in sender.
NEXT_PUBLIC_AUTH_EMAIL=

# DB query observability (lib/db-log.ts) — timing + errors for Supabase calls
# are ON automatically in development. To force them ON in a production build,
# set DB_DEBUG=1 (server logs) and/or NEXT_PUBLIC_DB_DEBUG=1 (browser logs).
DB_DEBUG=
NEXT_PUBLIC_DB_DEBUG=

# --- Web Push reminders (M8 / CET-11) ---------------------------------------
# The SCHEDULE lives in Postgres (pg_cron every minute, migration 0013), because
# Vercel's Hobby plan caps cron at once per day — it can't fire a member's chosen
# clock time. pg_net then POSTs /api/push/dispatch, which is the sender.
#
# VAPID keypair — the browser subscribes with the PUBLIC key; the server signs
# with the PRIVATE one. They are a matched pair: replace one and every existing
# subscription stops working. Generate with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for the push services (spec-required; Apple rejects a push without it).
VAPID_SUBJECT=mailto:you@example.com

# Shared secret: pg_cron sends it as `Authorization: Bearer …`, and the dispatch
# route rejects anything else. The SAME value must be stored in Supabase Vault as
# `push_dispatch_secret` (with `push_dispatch_url` = https://<app>/api/push/dispatch),
# which is what the cron job reads. Absent → the job is a silent no-op.
PUSH_DISPATCH_SECRET=

# Server-only. The dispatcher acts for the system (claims due reminders across
# every member, prunes dead devices), so it bypasses RLS. Never expose this to
# the browser and never import lib/supabase/service.ts outside that route.
SUPABASE_SERVICE_ROLE_KEY=

# Dev-only one-tap sign-in — set to 1 in .env.local to show a "Dev sign-in
# (skip inbox)" button that sends a magic link and auto-follows it from the
# local Mailpit inbox. The server action is hard-gated to the local 127.0.0.1
# stack (app/dev-auth.ts). NEVER set this in Vercel / production.
NEXT_PUBLIC_AUTH_DEV=
